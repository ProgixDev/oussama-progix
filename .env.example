# Copy to .env.local and fill in real values (never commit real env files).
# Server vars are parsed in src/core/env.ts (server-only); client vars in
# src/core/env.client.ts. Unparsed env access fails review.
#
# ⚠️  NEXT_PUBLIC_* is inlined into the BROWSER bundle — never put a secret there.

# NODE_ENV is set by Next.js automatically.

# --- Supabase (public: safe in the browser; RLS is the boundary) ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-or-publishable-key"

# --- Frontend-only access gate (site-gate feature) ---
# ⚠️  PUBLIC: inlined into the browser bundle and readable in devtools. It only
# deters casual access — it is NOT a security boundary. Never gate real secrets
# with it. Set the code visitors must enter to open the site.
NEXT_PUBLIC_SITE_ACCESS_CODE="progix2026"

# --- Server-only secrets (NEVER prefix NEXT_PUBLIC_) ---
# service_role bypasses RLS — used only in trusted server code (account deletion).
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Example server-side variable (add to src/core/env.ts schema too):
# DATABASE_URL="postgres://user:password@localhost:5432/app"
